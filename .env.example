# ============================================================================
# Scantral — variables de entorno
# Copiar a `.env` y rellenar los valores. `.env` está en .gitignore.
# ============================================================================

# ---- Base de datos (Postgres) ----------------------------------------------
# El servicio `postgres` del docker-compose ya las inyecta como POSTGRES_*.
POSTGRES_DB=scantral
POSTGRES_USER=scantral
POSTGRES_PASSWORD=scantral_dev

# ---- Backend / Seguridad ---------------------------------------------------
# Secreto HMAC SHA-256 para firmar los JWT. Mínimo 32 bytes.
# Generar con: openssl rand -base64 48
JWT_SECRET=change-me-please-32-bytes-minimum-secret-key-1234567890
# Tiempo de vida del token en milisegundos (24h por defecto)
JWT_EXPIRATION_MS=86400000

# ---- Email (alertas de caducidad) ------------------------------------------
# Envío vía relay SMTP de Resend (https://resend.com).
#  - RESEND_API_KEY: API key generada en https://resend.com/api-keys
#  - MAIL_FROM:      remitente; debe pertenecer a un dominio previamente
#                    verificado en Resend (registros SPF/DKIM en el DNS).
# Si se dejan vacías, el envío de emails queda deshabilitado en runtime.
RESEND_API_KEY=
MAIL_FROM=

# ---- IA (Google Gemini) ----------------------------------------------------
# Clave de Google AI Studio (https://aistudio.google.com/apikey).
# Si se deja vacía, el pipeline cae directamente al OCR sidecar.
GOOGLE_API_KEY=
AI_MODEL=gemini-2.5-flash-lite

# ---- OCR sidecar (PaddleOCR) -----------------------------------------------
# Idioma del modelo PP-OCR: latin (default) cubre ES + EN. También: es, en, ch, ...
OCR_LANGUAGE=latin
# Timeout HTTP del backend al sidecar (ms)
OCR_TIMEOUT_MS=30000
